---
import Base from '../layouts/Base.astro';
import data from '../data/books.json';

export function getStaticPaths() {
  return Object.keys(data.books).map(cat => ({
    params: { category: cat },
  }));
}

const { category } = Astro.params;
const books = data.books[category] || [];
const total = data.categories[category] || 0;
const source = data.source;
---

<Base>
  <div class="container">
    <header>
      <h1>白雲深處人家</h1>
      <p>中華傳統道文化數字圖書館 · 書目索引</p>
      <p><a href={source} target="_blank">原始來源</a></p>
    </header>

    <div class="search-box">
      <input type="text" id="searchInput" placeholder="搜索书名、作者..." />
    </div>

    <nav class="nav-tabs">
      <a href="/">全部</a>
      {Object.entries(data.categories).map(([k, v]) => (
        <a href={`/${k}/`} class:list={[{ active: k === category }]}>{k} ({v})</a>
      ))}
    </nav>

    <p class="book-count">{category} · 共 {total} 冊</p>

    <div id="bookList" class="book-list"></div>
    <div id="pagination" class="pagination"></div>
  </div>

  <footer>
    <p>書目數據來源：<a href={source} target="_blank">白雲深處人家逍遙子</a></p>
  </footer>

  <script define:vars={{ BOOKS: books, BASE_URL: 'https://www.homeinmists.com/', PER_PAGE: 50 }}>
    let currentPage = 1;
    let filtered = [];

    function getSearchQuery() {
      return new URLSearchParams(window.location.search).get('q') || '';
    }

    function filterBooks() {
      const q = getSearchQuery().toLowerCase();
      if (!q) return BOOKS;
      return BOOKS.filter(b => b.title.toLowerCase().includes(q));
    }

    function renderList() {
      filtered = filterBooks();
      const totalP = Math.ceil(filtered.length / PER_PAGE);
      if (currentPage > totalP) currentPage = totalP || 1;
      const start = (currentPage - 1) * PER_PAGE;
      const page = filtered.slice(start, start + PER_PAGE);
      const list = document.getElementById('bookList');
      const q = getSearchQuery();

      if (page.length === 0) {
        list.innerHTML = '<div class="no-results">未找到匹配的書目</div>';
      } else {
        list.innerHTML = page.map(b => {
          let title = b.title;
          if (q) {
            const re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
            title = b.title.replace(re, '<span class="highlight">$1</span>');
          }
          const url = b.id.startsWith('http') ? b.id : BASE_URL + b.id;
          let fmt = '外鏈';
          if (b.format === 'pdf') fmt = 'PDF';
          else if (b.format === 'webpage') fmt = '網頁';
          const fmtClass = b.format;
          const idShort = b.id.replace(/^.*\//, '');
          return '<div class="book-item"><span class="book-id">' + idShort + '</span><span class="book-title">' + title + '</span><span class="book-format ' + fmtClass + '">' + fmt + '</span><a class="book-link" href="' + url + '" target="_blank">下載 ↗</a></div>';
        }).join('');
      }

      const pag = document.getElementById('pagination');
      if (totalP <= 1) { pag.innerHTML = ''; return; }
      let html = '';
      for (let i = 1; i <= totalP; i++) {
        if (i === currentPage) html += '<span class="current">' + i + '</span>';
        else html += '<a href="#" onclick="goPage(' + i + ');return false">' + i + '</a>';
      }
      pag.innerHTML = html;
    }

    window.goPage = function(p) { currentPage = p; renderList(); window.scrollTo(0, 0); };

    const input = document.getElementById('searchInput');
    input.value = getSearchQuery();
    let debounce;
    input.addEventListener('input', function() {
      clearTimeout(debounce);
      debounce = setTimeout(function() {
        const q = input.value.trim();
        const url = new URL(window.location);
        if (q) url.searchParams.set('q', q); else url.searchParams.delete('q');
        history.replaceState(null, '', url);
        currentPage = 1;
        renderList();
      }, 300);
    });

    renderList();
  </script>
</Base>
