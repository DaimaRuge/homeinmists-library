---
export interface Props {
  sortedTags: [string, number][];
  totalEntries: number;
  source: string;
  lastUpdated?: string;
  activeTag?: string;
}

const { sortedTags, totalEntries, source, lastUpdated, activeTag } = Astro.props;
---
<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="琅嬛福地·中華傳統道文化數字圖書館書目索引" />
  <link rel="icon" type="image/x-icon" href="https://www.homeinmists.com/DaoD/%E3%80%87.ico" />
  <title>琅嬛福地 · 中華傳統道文化數字圖書館</title>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600;700&display=swap');
    *{margin:0;padding:0;box-sizing:border-box}
    :root{--bg:#f5f0e8;--text:#2c3e2d;--text-light:#5a6b5a;--text-muted:#8a9a8a;--accent:#2d5016;--accent-light:#5b8a3c;--accent-pale:#8fbc8f;--card-bg:rgba(255,253,248,0.75);--border:rgba(45,80,22,0.12);--tag-bg:rgba(143,188,143,0.15);--shadow:rgba(45,80,22,0.08);--sidebar-w:220px}
    body{font-family:'Noto Serif SC',serif;background:var(--bg);color:var(--text);line-height:1.8}
    body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(180,165,130,0.03) 2px,rgba(180,165,130,0.03) 4px),radial-gradient(ellipse 80% 50% at 20% 10%,rgba(212,197,169,0.3) 0%,transparent 70%),radial-gradient(ellipse 60% 40% at 80% 20%,rgba(143,188,143,0.15) 0%,transparent 60%),linear-gradient(175deg,#f5f0e8 0%,#efe8d8 40%,#f0ebe0 70%,#f5f0e8 100%);pointer-events:none;z-index:-2}
    .page-wrap{display:flex;max-width:1400px;margin:0 auto;min-height:100vh}
    .sidebar{width:var(--sidebar-w);flex-shrink:0;padding:1.5rem 0 2rem 1.5rem;position:sticky;top:0;height:100vh;overflow-y:auto;border-right:1px solid var(--border);background:rgba(245,240,232,0.6);backdrop-filter:blur(8px)}
    .sidebar-logo{text-align:center;padding:1.5rem 0.5rem 1rem;margin-bottom:1rem;border-bottom:1px solid var(--border)}
    .sidebar-logo h1{font-size:1.5rem;font-weight:700;background:linear-gradient(135deg,var(--accent),var(--accent-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:.12em}
    .sidebar-logo p{color:var(--text-muted);font-size:.75rem;margin-top:.25rem}
    .sidebar-search{padding:0 .5rem;margin-bottom:.75rem;position:relative}
    .sidebar-search input{width:100%;padding:.5rem .75rem .5rem 2rem;border:1px solid var(--border);border-radius:1.5rem;font-size:.85rem;font-family:inherit;background:var(--card-bg);color:var(--text);outline:none}
    .sidebar-search input:focus{border-color:var(--accent-pale);box-shadow:0 2px 12px var(--shadow)}
    .sidebar-search::before{content:'🔍';position:absolute;left:.8rem;top:50%;transform:translateY(-50%);font-size:.75rem}
    .sidebar-stats{padding:0 .75rem;margin-bottom:.75rem;font-size:.78rem;color:var(--text-muted);display:flex;justify-content:space-between}
    .sidebar-nav{padding:0 .5rem}
    .sidebar-nav a{display:flex;justify-content:space-between;align-items:center;padding:.35rem .65rem;border-radius:.3rem;text-decoration:none;color:var(--text);font-size:.82rem;transition:all .2s;line-height:1.5}
    .sidebar-nav a:hover{background:var(--tag-bg);color:var(--accent)}
    .sidebar-nav a.active{background:linear-gradient(135deg,var(--accent),var(--accent-light));color:#fff;font-weight:600}
    .sidebar-nav .count{font-size:.72rem;opacity:.7;font-weight:300}
    .sidebar-nav a.active .count{opacity:.9}
    .sidebar-footer{padding:1rem .75rem 0;margin-top:1rem;border-top:1px solid var(--border);font-size:.72rem;color:var(--text-muted);line-height:1.6}
    .sidebar-footer a{color:var(--accent-light);text-decoration:none}
    .main-content{flex:1;min-width:0;padding:1.5rem 2rem 2rem}
    .cat-header{margin-bottom:1rem;padding-bottom:.75rem;border-bottom:1px solid var(--border)}
    .cat-header h2{font-size:1.3rem;font-weight:600;color:var(--accent)}
    .cat-header .cat-desc{font-size:.85rem;color:var(--text-light);font-weight:300}
    .cat-header .cat-count{font-size:.8rem;color:var(--text-muted);margin-top:.2rem}
    .mobile-header{display:none;text-align:center;padding:1rem;border-bottom:1px solid var(--border);background:rgba(245,240,232,.8);position:sticky;top:0;z-index:100}
    .mobile-header h1{font-size:1.4rem;font-weight:700;background:linear-gradient(135deg,var(--accent),var(--accent-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:.1em}
    .mobile-toggle{display:none;background:none;border:1px solid var(--border);border-radius:.4rem;padding:.4rem .8rem;font-family:inherit;font-size:.85rem;color:var(--text);cursor:pointer;margin:.5rem auto;background:var(--card-bg)}
    .mobile-search{display:none;padding:0 1rem .75rem}
    .mobile-search input{width:100%;padding:.6rem 1rem;border:1px solid var(--border);border-radius:1.5rem;font-size:.9rem;font-family:inherit;background:var(--card-bg);color:var(--text);outline:none}
    .book-item{border-bottom:1px solid rgba(45,80,22,.06)}
    .book-row{display:flex;align-items:center;gap:.75rem;padding:.55rem .75rem;cursor:pointer;transition:background .2s}
    .book-row:hover{background:rgba(143,188,143,.06)}
    .book-row .arrow{font-size:.6rem;color:var(--text-muted);transition:transform .2s;flex-shrink:0;width:1em;text-align:center}
    .book-row.open .arrow{transform:rotate(90deg)}
    .book-row .b-core{flex:1;min-width:0}
    .book-row .b-title{font-size:.9rem;line-height:1.5;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .book-row .b-title .hl{background:rgba(143,188,143,.25);padding:0 2px;border-radius:2px;color:var(--accent)}
    .book-row .b-brief{font-size:.75rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:.1rem}
    .book-row .b-dl{font-size:.85rem;color:var(--accent);text-decoration:none;flex-shrink:0;padding:.15rem .3rem;border-radius:.25rem;transition:all .2s;opacity:.6}
    .book-row .b-dl:hover{opacity:1;background:rgba(143,188,143,.1)}
    .book-row .b-fmt{font-size:.68rem;padding:.1rem .4rem;border-radius:.25rem;background:var(--tag-bg);color:var(--text-muted);border:1px solid rgba(143,188,143,.15);flex-shrink:0}
    .book-row .b-fmt.pdf{background:rgba(45,80,22,.08);color:var(--accent)}
    .book-detail{display:none;padding:0 .75rem .75rem 2rem;border-left:2px solid var(--accent-pale);margin-left:.75rem}
    .book-detail.open{display:block}
    .book-detail .d-row{font-size:.82rem;margin-bottom:.25rem}
    .book-detail .d-label{color:var(--text-muted);display:inline-block;min-width:3.5em}
    .book-detail .d-desc{font-size:.83rem;color:var(--text-light);font-weight:300;margin:.5rem 0 .3rem;padding:.4rem .5rem;background:rgba(143,188,143,.06);border-radius:.3rem}
    .book-detail .d-tags{display:flex;gap:.3rem;flex-wrap:wrap;margin:.3rem 0}
    .book-detail .d-tag{font-size:.72rem;padding:.1rem .45rem;border-radius:.25rem;background:rgba(91,138,60,.1);color:var(--accent-light);border:1px solid rgba(91,138,60,.15)}
    .book-detail .d-link{display:inline-block;margin-top:.3rem;font-size:.82rem;color:var(--accent);text-decoration:none;padding:.25rem .7rem;border:1px solid var(--accent-pale);border-radius:.3rem;transition:all .2s}
    .book-detail .d-link:hover{background:var(--accent);color:#fff}
    .pagination{display:flex;justify-content:center;gap:.3rem;margin-top:1.5rem;flex-wrap:wrap}
    .pagination a,.pagination span{padding:.35rem .7rem;border:1px solid var(--border);border-radius:.3rem;text-decoration:none;color:var(--text);font-size:.85rem;background:var(--card-bg)}
    .pagination .current{background:linear-gradient(135deg,var(--accent),var(--accent-light));color:#fff;border-color:var(--accent)}
    .pagination a:hover{background:var(--tag-bg);border-color:var(--accent-pale)}
    .no-results{text-align:center;padding:3rem;color:var(--text-light)}
    @media(max-width:860px){.mobile-header,.mobile-toggle,.mobile-search{display:block}.sidebar{position:fixed;top:0;left:0;height:100vh;z-index:200;transform:translateX(-100%);transition:transform .3s;background:rgba(245,240,232,.97);box-shadow:4px 0 20px rgba(0,0,0,.1)}.sidebar.open{transform:translateX(0)}.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:199}.sidebar-overlay.open{display:block}.sidebar-logo{display:none}.main-content{padding:1rem}.page-wrap{flex-direction:column}}
    @media(min-width:861px){.mobile-header,.mobile-toggle,.mobile-search{display:none}.sidebar-overlay{display:none!important}}
    ::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--accent-pale);border-radius:3px}
  </style>
</head>
<body>
  <div class="mobile-header">
    <h1>琅嬛福地</h1>
    <button class="mobile-toggle" id="menuToggle">☰ 分類導航</button>
    <div class="mobile-search"><input type="text" id="mobileSearchInput" placeholder="搜索書名、標籤..." /></div>
  </div>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <div class="page-wrap">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo"><h1>琅嬛福地</h1><p>中華傳統道文化數位圖書館</p></div>
      <div class="sidebar-search"><input type="text" id="searchInput" placeholder="搜索書名、標籤..." /></div>
      <div class="sidebar-stats"><span>共 {totalEntries} 冊</span><span>{sortedTags.length} 類</span></div>
      <nav class="sidebar-nav" id="sidebarNav">
        <a href="/" class:list={[{ active: !activeTag }]}>全部</a>
        {sortedTags.map(([t, c]) => <a href={`/${encodeURIComponent(t)}/`} class:list={[{ active: t === activeTag }]}><span>{t}</span><span class="count">{c}</span></a>)}
      </nav>
      <div class="sidebar-footer">數據來源：<a href={source} target="_blank">白雲深處人家</a>{lastUpdated && <> · 更新：{lastUpdated}</>}</div>
    </aside>
    <main class="main-content">
      <slot />
    </main>
  </div>
  <script>
    // Mobile sidebar toggle — use menuBtn, NOT toggle (toggle is the book expand function)
    var menuBtn = document.getElementById('menuToggle');
    var sidebar = document.querySelector('.sidebar');
    var overlay = document.getElementById('sidebarOverlay');
    if (menuBtn && sidebar) {
      menuBtn.addEventListener('click', function() {
        sidebar.classList.toggle('open');
        overlay.classList.toggle('open');
      });
      overlay.addEventListener('click', function() {
        sidebar.classList.remove('open');
        overlay.classList.remove('open');
      });
    }
    var mi = document.getElementById('mobileSearchInput');
    var si = document.getElementById('searchInput');
    if (mi && si) {
      mi.addEventListener('input', function() { si.value = mi.value; si.dispatchEvent(new Event('input')); });
    }
  </script>
</body>
</html>
